{
  "system_name": "小龙智能交易系统",
  "version": "1.0",
  "monitoring": {
    "enabled": true,
    "check_interval": 60,
    "max_symbols": 20,
    "update_interval": 3600,
    "price_alert_threshold": 0.1,
    "volatility_alert_threshold": 1.0
  },
  "trading": {
    "enabled": false,
    "max_position_usd": 50,
    "leverage": 10,
    "stop_loss_pct": 0.005,
    "take_profit_pct": 0.015,
    "min_signal_confidence": 0.7,
    "max_trades_per_day": 5
  },
  "notification": {
    "telegram_enabled": false,
    "notion_enabled": false
  }
}
