{
  "_comment": "主网安全验证模式 - 极小资金验证真实成交数据",
  "_purpose": "验证 fetch_my_trades 返回真实 PnL，不是优化系统",
  
  "enabled": true,
  "check_interval": 30,
  "paper_trading": false,
  "shadow_mode": false,
  
  "_safety_note": "⚠️ 主网真实资金，但风险可控",
  
  "leverage": 2,
  "margin_usd": 1,
  "notional_usd": 2,
  "max_position_usd": 5,
  
  "max_daily_trades": 10,
  
  "_hard_lock": "🔒 硬锁 - 达到上限强制停止，不可绕过",
  "MAX_TRADES_HARD_LIMIT": 10,
  "MIN_TRADE_INTERVAL_SECONDS": 60,
  
  "min_signal_interval_seconds": 60,
  
  "symbols": ["ETH/USDT:USDT"],
  
  "scoring": {
    "entry_threshold": 60,
    "weights": {
      "trend_consistency": 30,
      "pullback_breakout": 20,
      "volume_confirm": 15,
      "spread_quality": 15,
      "volatility_range": 10,
      "rl_filter": 10
    }
  },
  
  "exit": {
    "hard_stop_loss_pct": 0.02,
    "take_profit_layers_pct": [0.01],
    "max_hold_seconds": 60,
    "condition_fail_exit": true
  },
  
  "risk_metrics": {
    "max_daily_loss_usd": 2,
    "max_single_loss_usd": 1,
    "max_slippage_bps": 10,
    "max_query_failures": 3,
    "freeze_on_anomaly": true
  },
  
  "kill_switch": {
    "max_consecutive_failures": 2,
    "max_daily_loss_pct": 5,
    "enabled": true
  },
  
  "_validation_targets": {
    "trade_count": 10,
    "verify": [
      "fetch_my_trades 有数据",
      "pnl 分布自然（不再 0.0000%）",
      "entry ≠ exit"
    ]
  },
  
  "system_version": "V5.3-MAINNET-SAFETY"
}