+    def _authorize_execution(self, symbol: str, score: float, volume_ratio: float, price_change: float, regime: str, current_price: float, should_trade: bool, decision_trace: Dict, gate_reason: str) -> Dict[str, Any]:
+        """统一交易授权结果。"""
+        volatility = float(decision_trace.get('volatility', 0.0) or 0.0)
+        spread_bps = float(decision_trace.get('spread_bps', 2.0) or 2.0)
+        authorization = {
+            'timestamp': datetime.now().isoformat(),
+            'symbol': symbol,
+            'signal_score': float(score),
+            'volume_ratio': float(volume_ratio),
+            'price_change': float(price_change),
+            'regime': regime,
+            'current_price': float(current_price),
+            'volatility': volatility,
+            'spread_bps': spread_bps,
+            'gate_decision': decision_trace.get('final', 'UNKNOWN'),
+            'gate_reason': gate_reason,
+            'authorized': False,
+            'decision_source': 'base_gate',
+            'decision_type': 'REJECT',
+            'trace_id': f"gate-{datetime.now().strftime('%Y%m%d%H%M%S%f')}",
+            'checks': {
+                'score_ok': bool(decision_trace.get('score_ok', False)),
+                'volume_ok': bool(decision_trace.get('volume_ok', False)),
+                'price_change_ok': bool(decision_trace.get('price_change_ok', True)),
+            },
+            'reasons': [gate_reason],
+        }
+
+        if not should_trade:
+            return authorization
+
+        decision = self.decision_hub.evaluate(
+            signal={'latency_ms': 0},
+            symbol=symbol,
+            price=current_price,
+            score=float(score),
+            regime=regime
+        )
+        authorization.update({
+            'authorized': bool(decision.can_trade and decision.authorized),
+            'decision_source': 'decision_hub',
+            'decision_type': decision.decision_type.name,
+            'trace_id': decision.trace_id,
+            'checks': decision.checks,
+            'reasons': decision.reasons,
+            'position_multiplier': float(decision.position_multiplier),
+            'decision_hash': decision.decision_hash,
+        })
+        print(f"[DECISION_HUB] decision={decision.decision_type.name} authorized={decision.authorized} trace_id={decision.trace_id}")
+        return authorization
