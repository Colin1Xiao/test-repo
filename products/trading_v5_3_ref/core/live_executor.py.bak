    async def get_best_price_fast(self, symbol: str) -> Tuple[float, float, float]:
        """
        快速获取价格（使用价格缓存，0ms 读取）
        
        包含保护机制：
        1. 数据新鲜度检查
        2. 价格偏差验证
        
        Returns:
            (bid, ask, mid) 或引发异常
        """
        # 直接从价格缓存读取（0ms）
        if self._price_cache:
            price_data = self._price_cache.get_price(symbol)
            
            if price_data:
                # 🔒 数据新鲜度保护
                ts_str = price_data.get('timestamp', '')
                if ts_str:
                    from datetime import datetime
                    try:
                        ts = datetime.fromisoformat(ts_str)
                        age = (datetime.now() - ts).total_seconds()
                        if age > 1.0:  # 超过1秒
                            print(f"⚠️ 价格数据过期: {age*1000:.0f}ms")
                            # Fallback REST
                            return await self.get_best_price(symbol)
                    except:
                        pass  # 解析失败，继续使用缓存价格
                
                return price_data['bid'], price_data['ask'], price_data['mid']
        
        # Fallback REST
        return await self.get_best_price(symbol)
    async def close(self):
        """关闭连接"""
        await self.exchange.close()


