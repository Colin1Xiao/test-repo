            pass

    async def test():
        exchange = MockExchange()
        safe_exec = SafeExecutionV54(exchange)

        # 测试 Position Gate
        can_open, reason = await safe_exec.position_gate.can_open()
        print(f"can_open: {can_open}, reason: {reason}")

        # 测试开仓
        result = await safe_exec.execute_entry(signal_price=2000, margin_usd=3.0)
        print(f"开仓结果: {result}")

        # 测试 TIME_EXIT
        result = await safe_exec.check_time_exit()
        print(f"TIME_EXIT 结果: {result}")

    asyncio.run(test())