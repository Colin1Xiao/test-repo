# GitHub Live Validation 配置模板
# 复制此文件为 .env.github 并填写真实值

# GitHub Token (必需)
# 创建步骤：https://github.com/settings/tokens
# 权限：repo + admin:repo_hook
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Webhook Secret (必需)
# 生成命令：openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# 测试仓库 Owner (必需)
GITHUB_TEST_OWNER=your-github-username

# 测试仓库名称 (必需)
GITHUB_TEST_REPO=test-repo

# Webhook URL (可选，运行 ngrok 后自动填充)
# GITHUB_WEBHOOK_URL=https://abc123.ngrok.io/webhook/github

# 自动创建测试 PR (可选)
GITHUB_CREATE_TEST_PR=true

# 自动清理测试 PR (可选)
GITHUB_AUTO_CLEANUP=true

# 测试 Reviewer 列表 (可选)
GITHUB_TEST_REVIEWERS=colin,tester

# 验证模式 (dry-run | live)
GITHUB_VALIDATION_MODE=live
