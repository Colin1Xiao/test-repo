                'win_rate': self._calculate_win_rate(),
                'avg_pnl': self.stats['daily_pnl'] / max(1, len(self.trade_history))
            })
            
            return {
                'symbol': symbol,
                'regime': regime.value,
                'score': score,
                'volume_ratio': volume_ratio,
                'should_trade': should_trade,
                'trade': trade,
                'cycle_time': time.time() - cycle_start
            }
            
        except Exception as e:
            print(f"❌ 周期错误: {e}")
            import traceback
            traceback.print_exc()
            return None
    
    def _log_decision(self, symbol: str, score: float, volume_ratio: float, 
                      decision_trace: Dict, regime: str):
        """
        写入决策日志
        """
        try:
            # 转换 numpy 类型为 Python 原生类型
            def to_python(v):
                if hasattr(v, 'item'):  # numpy 类型
                    return v.item()
                return v
            
            log_entry = {
                'timestamp': datetime.now().isoformat(),
                'symbol': symbol,
                'score': to_python(score),
                'volume_ratio': to_python(volume_ratio),
                'regime': regime,
                'decision': str(decision_trace.get('final', 'UNKNOWN')),
                'checks': {
                    'score_ok': bool(decision_trace.get('score_ok', False)),
                    'volume_ok': bool(decision_trace.get('volume_ok', False)),
                    'price_change_ok': bool(decision_trace.get('price_change_ok', True))
                },
                'context': {
                    'symbol': symbol,
                    'score': to_python(score),
                    'volume': to_python(volume_ratio),
                    'regime': regime
                }
            }
            
            log_file = BASE_DIR / 'logs' / 'decision_log.jsonl'
            with open(log_file, 'a') as f:
                f.write(json.dumps(log_entry) + '\n')
        except Exception as e:
            print(f"⚠️ 写入决策日志失败: {e}")
    
    def _check_execution_conditions(
        self,
        score: float,
        volume_ratio: float,
        strategy_config: Dict[str, Any],
        price_change: float = 0.0  # V2: 新增动量过滤
    ) -> tuple:
        """
        检查执行条件（带决策追踪）- V2 策略
        
        Returns:
            (should_trade, reason, decision_trace)
        """
        # 🔥 Smoke Test 模式：临时降低阈值
        if SMOKE_TEST_MODE:
            min_score = SMOKE_TEST_THRESHOLD  # 使用 Smoke Test 阈值 (50)
            min_volume = 0.1  # 大幅降低成交量要求
            min_price_change = -1.0  # 禁用动量过滤（允许负值）
            print(f"🔥 [SMOKE TEST] 使用临时阈值: score={min_score}, volume={min_volume}, momentum={min_price_change}")
        else:
            min_score = strategy_config.get('min_score', 70)  # V2: 默认70
            min_volume = strategy_config.get('min_volume', 1.2)  # V2: 默认1.2
            min_price_change = strategy_config.get('min_price_change', 0.0)  # V2: 动量过滤
        
        # 决策追踪
        decision = {
            'score': score,
            'volume_ratio': volume_ratio,
            'price_change': price_change,
            'min_score': min_score,
            'min_volume': min_volume,
            'min_price_change': min_price_change,
            'score_ok': score >= min_score,
            'volume_ok': volume_ratio >= min_volume,
            'price_change_ok': price_change >= min_price_change,  # V2
            'spread_ok': True,  # TODO: 实际检查
            'depth_ok': True,   # TODO: 实际检查
            'slippage_ok': True, # TODO: 实际检查
            'final': 'PENDING'
        }
        
        if score < min_score:
            decision['final'] = 'REJECT_SCORE'
            return False, f"评分不足: {score} < {min_score}", decision
        
        if volume_ratio < min_volume:
            decision['final'] = 'REJECT_VOLUME'
            return False, f"成交量不足: {volume_ratio:.2f}x < {min_volume}x", decision
        
        # V2: 动量过滤
        if min_price_change > 0 and price_change < min_price_change:
            decision['final'] = 'REJECT_MOMENTUM'
            return False, f"动量不足: {price_change*100:.2f}% < {min_price_change*100:.2f}%", decision
        
        decision['final'] = 'ACCEPT'
        return True, "条件满足", decision
    
    async def _execute_trade(self, symbol: str, score: float, regime: MarketRegime) -> Optional[Dict[str, Any]]:
        """
        执行真实交易 - V5.4 安全执行链
        
        使用 SafeExecutor 确保:
        1. 单执行入口
        2. Execution Lock
        3. 双层 Position Gate
        4. 订单级止损
        5. 止损验证
        """
        import time
        
        print(f"\n{'='*50}")
        print(f"⚡ [SafeExecutor] EXECUTION START")
        print(f"{'='*50}")
        print(f"📍 Symbol: {symbol}")
        print(f"📍 Score: {score}")
        print(f"📍 Regime: {regime.value}")
        
        # 🚨 检查是否禁用旧执行链
        if not DISABLE_EXECUTION_ENGINE:
            print(f"❌ CRITICAL: DISABLE_EXECUTION_ENGINE = False，拒绝执行")
            return None
        
        # 🚨 检查 SafeExecutor 是否初始化
        if not hasattr(self, 'safe_executor') or self.safe_executor is None:
            print(f"❌ SafeExecutor 未初始化")
            return None
        
        # 🎯 动态保证金计算
        equity_usdt = await self.get_account_equity_usdt()
        
        # 获取最小订单大小
        market_info = await self.exchange.load_markets()
        min_order_size = market_info.get(symbol, {}).get('limits', {}).get('amount', {}).get('min', 0.01)
        requested_notional = 300.0  # 默认名义价值
        
        print(f"[PRE_TRADE_CHECK] available_balance={equity_usdt:.2f}USDT balance_source=exchange_runtime requested_notional={requested_notional}USDT min_order_size={min_order_size}ETH")
        entry_price = float(current_price) if 'current_price' in dir() else 0.0
        
        # 尝试从 analyzer 获取当前价格
        if entry_price == 0.0 and hasattr(self, 'analyzer'):
            try:
                ticker = await self.analyzer.fetch_ticker(symbol)
                entry_price = float(ticker.get('last', 0))
            except:
                entry_price = 2140.0  # 默认值
        
        current_drawdown = float(getattr(self, "current_drawdown", 0.0))
        edge_state = getattr(self, "edge_state", "STRONG")
        risk_state = getattr(self, "risk_state", "NORMAL")
        
        capital_decision = self.capital_controller.calculate(
            equity_usdt=equity_usdt,
            entry_price=entry_price,
            drawdown=current_drawdown,
            edge_state=edge_state,
            risk_state=risk_state,
        )
        
        if not capital_decision.can_trade:
            print(f"⛔ Capital blocked trade: {capital_decision.reason}")
            return None
        
        print(
            f"💰 Capital | equity={capital_decision.equity_usdt:.2f} "
            f"margin={capital_decision.margin_usdt:.2f} "
            f"notional={capital_decision.notional_usdt:.2f} "
            f"size={capital_decision.position_size:.6f} "
            f"state={capital_decision.capital_state} "
            f"risk_pct={capital_decision.risk_pct * 100:.2f}%"
        )
        
        # 执行交易 (异步方法，直接 await)
        try:
            result = await self.safe_executor.try_execute(
                "buy",
                capital_decision.position_size,
                context={
                    "requested_position_size": capital_decision.position_size,  # 理论值
                    "entry_price": entry_price,  # 入场价格
                    "margin_usdt": capital_decision.margin_usdt,
                    "notional_usdt": capital_decision.notional_usdt,
                    "equity_usdt": capital_decision.equity_usdt,
                    "capital_state": capital_decision.capital_state,
                    "capital_reason": capital_decision.reason,
                    "leverage": capital_decision.leverage,
                    "risk_pct": capital_decision.risk_pct,
                    "smoke_test_mode": SMOKE_TEST_MODE,  # 生产: False, Smoke Test: True
                },
            )
        except Exception as e:
            print(f"❌ SafeExecutor 执行失败: {e}")
            import traceback
            traceback.print_exc()
            return None
        
        if result is None:
            print(f"⛔ 被 Position Gate 或 Execution Lock 拦截")
            return None
        
        # 构建返回记录
        trade = {
            'timestamp': datetime.now().isoformat(),
            'symbol': symbol,
            'regime': regime.value,
            'score': score,
            'volume_ratio': 0,
            'price': result.get('entry_price'),
            'mode': 'live',
            'execution_time': 0,
            'order_result': result,
            'slippage': 0,
            'latency': 0,
            'net_pnl': 0,
            'gross_pnl': 0,
            'fee': 0,
            'signal_quality': 0.5,
            'execution_quality': 1.0,
            'stop_ok': result.get('stop_ok', False),
            'stop_verified': result.get('stop_verified', False),
        }
        
        print(f"✅ [SafeExecutor] 执行成功")
        print(f"   Entry Price: ${result.get('entry_price', 0):.2f}")
        print(f"   Position Size: {result.get('position_size', 0):.4f}")
        print(f"   Stop Price: ${result.get('stop_price', 0):.2f}")
        print(f"   Stop OK: {result.get('stop_ok', False)}")
        print(f"   Stop Verified: {result.get('stop_verified', False)}")
        print(f"{'='*50}\n")
        
        return trade
    
    def _evaluate_signal_quality(self, trade: Dict[str, Any]) -> float:
        """评估信号质量"""
        # 简化实现
        score = trade.get('score', 0)
        volume_ratio = trade.get('volume_ratio', 0)
        
        quality = min(1.0, (score / 100) * 0.6 + min(1.0, volume_ratio / 2.0) * 0.4)
        return quality
    
    def _evaluate_execution_quality(self, trade: Dict[str, Any]) -> float:
        """评估执行质量"""
        slippage = abs(trade.get('slippage', 0))
        latency = trade.get('latency', 0)
        
        # 滑点评分 (0.05%为满分，0.2%为0分)
        slippage_score = max(0, 1 - slippage / 0.002)
        
        # 延迟评分 (100ms为满分，1s为0分)
        latency_score = max(0, 1 - latency / 1.0)
        
        return (slippage_score + latency_score) / 2
    
    async def _time_exit_monitor(self, interval: float = 1.0):
        """
        🔥 V5.4 修复：独立的 TIME_EXIT 检查循环
        
        每 1 秒检查一次持仓时间，确保 TIME_EXIT 精确触发
        
        Args:
            interval: 检查间隔（秒），默认 1 秒
        """
        print(f"⏱️ TIME_EXIT 监控启动 (间隔: {interval}s)")
        
        while self.running:
            try:
                # 检查 SafeExecutor 是否有持仓
                if hasattr(self, 'safe_executor') and self.safe_executor:
                    pos = self.safe_executor.current_position
                    if pos:
                        entry_time = pos.get("entry_time", 0)
                        hold_time = time.time() - entry_time
                        max_hold = 45.0  # V2: MAX_HOLD_SECONDS 30s → 45s
                        
                        if hold_time >= max_hold:
                            print(f"\n⏱️ TIME_EXIT 触发!")
                            print(f"   hold_time: {hold_time:.1f}s >= {max_hold}s")
                            
                            # 执行平仓
                            result = await self.safe_executor.close_position("TIME_EXIT", "time_exit_monitor")
                            
                            if result:
                                print(f"   ✅ 平仓成功")
                                print(f"   入场: ${result['entry_price']:.2f}")
                                print(f"   平仓: ${result['exit_price']:.2f}")
                                print(f"   PnL: {result['pnl_pct']:.4f}%")
                                print(f"   hold_time: {result['hold_time']:.1f}s")
                                
                                # 🔥 关键修复：通知 position_manager 清除状态
                                if hasattr(self, 'position_manager'):
                                    self.position_manager.close_position('ETH/USDT:USDT')
                                    print(f"   ✅ position_manager 状态已清除")
                            else:
                                print(f"   ❌ 平仓失败")
                
                await asyncio.sleep(interval)
                
            except asyncio.CancelledError:
                print("⏱️ TIME_EXIT 监控已停止")
                break
            except Exception as e:
                print(f"⚠️ TIME_EXIT 监控异常: {e}")
                await asyncio.sleep(interval)
    
    def _calculate_win_rate(self) -> float:
        """计算胜率"""
        total = self.stats['win_count'] + self.stats['loss_count']
        if total == 0:
            return 0.5
        return self.stats['win_count'] / total
    
    def _calculate_avg_slippage(self) -> float:
        """计算平均滑点"""
        if not self.trade_history:
            return 0.0
        return sum(abs(t.get('slippage', 0)) for t in self.trade_history) / len(self.trade_history)
    
    def _calculate_avg_exec_quality(self) -> float:
        """计算平均执行质量"""
        if not self.trade_history:
            return 1.0
        return sum(t.get('execution_quality_score', 1.0) for t in self.trade_history) / len(self.trade_history)
    
    def _calculate_avg_signal_quality(self) -> float:
        """计算平均信号质量"""
        if not self.trade_history:
            return 0.5
        return sum(t.get('signal_quality', 0.5) for t in self.trade_history) / len(self.trade_history)
    
    async def run(self, interval: int = 10, max_cycles: int = 0):
        """
        运行系统主循环
        
        Args:
            interval: 检查间隔（秒）
            max_cycles: 最大周期数（0=无限）
        """
        self.running = True
        self.start_time = datetime.now()
        
        symbols = self.config.get('symbols', ['BTC/USDT:USDT'])
        
        print(f"\n🚀 开始运行，检查间隔: {interval}s")
        print(f"   监控标的: {symbols}")
        print(f"   ⏱️ TIME_EXIT 检查间隔: 1s (独立循环)")
        print(f"   按 Ctrl+C 停止\n")
        
        # 🚨 V5.4: 禁用旧执行引擎
        if DISABLE_EXECUTION_ENGINE:
            print(f"   ⚠️ 旧执行引擎已禁用 (SafeExecutor 模式)\n")
        elif self.execution_engine:
            self.execution_engine.start()
        
        # 🚀 V5.4 修复：启动独立的 TIME_EXIT 检查循环（1秒间隔）
        time_exit_task = asyncio.create_task(self._time_exit_monitor(interval=1.0))
        
        try:
            while self.running:
                if max_cycles > 0 and self.cycles >= max_cycles:
                    print(f"\n达到最大周期数 {max_cycles}，停止运行")
                    break
                
                for symbol in symbols:
                    result = await self.run_cycle(symbol)
                    
                    if result and result.get('action') == 'stop':
                        print("\n🛑 守护者触发停止，系统退出")
                        self.running = False
                        break
                
                # 定期输出统计
                if self.cycles % 30 == 0:
                    self._print_stats()
                
                await asyncio.sleep(interval)
                
        except KeyboardInterrupt:
            print("\n\n👋 用户中断，停止运行")
        
        finally:
            # 🔥 核心修复：退出前必须检查并平仓
            self.running = False
            
            # 检查是否有持仓
            if hasattr(self, 'safe_executor') and self.safe_executor:
                pos = self.safe_executor.current_position
                if pos:
                    print(f"\n🚨 检测到持仓，执行最终平仓...")
                    try:
                        close_result = await self.safe_executor.close_position(
                            "SYSTEM_SHUTDOWN",
                            "finally_block"
                        )
                        if close_result:
                            print(f"   ✅ 最终平仓成功")
                            print(f"   PnL: {close_result['pnl_pct']:.4f}%")
                        else:
                            print(f"   ❌ 最终平仓失败")
                    except Exception as e:
                        print(f"   ❌ 平仓异常: {e}")
            
            # 停止 TIME_EXIT 监控
            time_exit_task.cancel()
            
            # 🛑 停止执行引擎 (仅当使用旧引擎时)
            if not DISABLE_EXECUTION_ENGINE and self.execution_engine:
                self.execution_engine.stop()
                print(self.execution_engine.report())
            
            self._print_final_report()
    
    def _print_stats(self):
        """打印统计信息"""
        elapsed = (datetime.now() - self.start_time).total_seconds() if self.start_time else 0
        
        print(f"\n📊 运行统计 [{datetime.now().strftime('%H:%M:%S')}]")
        print(f"   运行时间: {elapsed/60:.1f}分钟")
        print(f"   周期数: {self.cycles}")
        print(f"   信号数: {self.stats['total_signals']}")
        print(f"   有效执行: {self.stats['valid_executions']}")
        print(f"   拒绝样本: {self.stats['rejected_samples']}")
        print(f"   当前Regime: {self.last_regime.value if self.last_regime else 'unknown'}")
    
    def _print_final_report(self):
        """打印最终报告"""
        print("\n" + "=" * 70)
        print("📋 V5.2 运行报告")
        print("=" * 70)
        
        elapsed = (datetime.now() - self.start_time).total_seconds() if self.start_time else 0
        
        print(f"\n运行时间: {elapsed/60:.1f} 分钟")
        print(f"总周期数: {self.cycles}")
        print(f"\n信号统计:")
        print(f"  - 检测信号: {self.stats['total_signals']}")
        print(f"  - 执行信号: {self.stats['executed_signals']}")
        print(f"  - 有效样本: {self.stats['valid_executions']}")
        print(f"  - 拒绝样本: {self.stats['rejected_samples']}")
        print(f"\n安全统计:")
        print(f"  - 守护者停止: {self.stats['guardian_stops']}")
        print(f"  - 安全回滚: {self.stats['safety_rollbacks']}")
        
        # Regime分布
        if self.regime_history:
            from collections import Counter
            regime_dist = Counter(self.regime_history)
            print(f"\nRegime分布:")
            for regime, count in regime_dist.items():
                pct = count / len(self.regime_history) * 100
                print(f"  - {regime}: {count} ({pct:.1f}%)")
        
        # 样本过滤统计
        filter_stats = self.sample_filter.get_stats()
        print(f"\n样本过滤:")
        print(f"  - 总样本: {filter_stats['total_samples']}")
        print(f"  - 有效率: {filter_stats['valid_rate']*100:.1f}%")
        
        # 获取监控汇总
        monitor_summary = self.monitor.get_summary()
        print(f"\n系统监控快照数: {monitor_summary.get('snapshot_count', 0)}")
        
        print("\n" + "=" * 70)


async def main():
    """主入口"""
    import argparse
    
    parser = argparse.ArgumentParser(description='小龙智能交易系统 V5.2')
    # 网络选择（互斥）
    network_group = parser.add_mutually_exclusive_group()
    network_group.add_argument('--testnet', action='store_true', dest='testnet', help='使用测试网（默认）')
    network_group.add_argument('--mainnet', action='store_true', dest='mainnet', help='使用主网（实盘）')
    # 执行模式（独立）
    parser.add_argument('--execute', action='store_true', help='执行模式（真实交易，非影子）')
    parser.add_argument('--shadow', action='store_true', help='影子模式（不真实执行）')
    parser.add_argument('--live', action='store_true', help='[已废弃] 请使用 --mainnet --execute')
    parser.add_argument('--interval', type=int, default=10, help='检查间隔（秒）')
    parser.add_argument('--cycles', type=int, default=0, help='最大周期数（0=无限）')
    parser.add_argument('--config', type=str, default=None, help='配置文件路径')
    
    args = parser.parse_args()
    
    # 网络选择：默认 testnet，除非显式指定 --mainnet
    # 修复：--live 是废弃参数，不再自动切换网络
    if args.mainnet:
        testnet = False
        print("⚠️  警告: 连接 MAINNET (主网)")
    else:
        testnet = True
        print("✅ 连接 TESTNET (测试网)")
    
    # 执行模式：默认 shadow，除非显式指定 --execute
    shadow_mode = not REAL_TRADING_MODE  # V5.4.1 灰度
    if args.shadow:
        shadow_mode = True
    
    # 废弃参数警告
    if args.live and not args.mainnet:
        print("⚠️  警告: --live 参数已废弃，请使用 --mainnet --execute")
        print("⚠️  当前行为: 仍连接 TESTNET，但执行模式")
    
    print(f"启动参数: network={'MAINNET' if not testnet else 'TESTNET'}, shadow_mode={shadow_mode}")
    
    # 创建系统
    system = V52System(
        config_path=args.config,
        testnet=testnet,
        shadow_mode=shadow_mode
    )
    
    # 运行
    await system.run(interval=args.interval, max_cycles=args.cycles)


if __name__ == '__main__':
    asyncio.run(main())