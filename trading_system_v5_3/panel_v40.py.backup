@app.route('/')
def index():
    s = load_stats()
    m = get_market()
    load_control()
    load_evolution()
    load_structure()
    load_decisions()
    t = s.get('total_trades', 0)
    pnl = s.get('total_pnl', 0)
    trades = s.get('trades', [])
    wr = round(s.get('wins',0)/t*100, 1) if t>0 else 0
    pr = round(s.get('signals_passed',0)/s.get('signals_checked',1)*100, 1) if s.get('signals_checked',0)>0 else 0
    wins = sum(x.get('pnl',0) for x in trades if x.get('pnl',0)>0)
    loss = abs(sum(x.get('pnl',0) for x in trades if x.get('pnl',0)<0))
    pf = round(wins/loss, 2) if loss>0 else 0
    return render_template_string(HTML, s=s, m=m, c=control, e=evolution_state, st=structure_state, d=decision_state, cap=capital_state, pos=position_state, t=t, pnl=round(pnl*100,4), wr=wr, pr=pr, pf=pf, trades=trades[-12:], logs=load_log(), now=datetime.now().strftime('%H:%M:%S'))

@app.route('/api/stats')
def api():
    s = load_stats()
    s['market'] = get_market()
    s['control'] = control
    s['evolution'] = evolution_state
    s['structure'] = structure_state
    s['decision'] = decision_state
    s['capital'] = capital_state
    s['position'] = position_state
    return jsonify(s)

@app.route('/api/control/<action>', methods=['POST'])
def ctrl(action):
    global control
    if action == 'enable': control.update({'enabled': True, 'frozen': False})
    elif action == 'disable': control['enabled'] = False
    elif action == 'freeze': control['frozen'] = True
    elif action == 'reset': control = {"enabled": True, "frozen": False, "threshold": 4, "last_update": None}
    save_control()
    return jsonify({"status": "ok", "control": control})

@app.route('/api/control/threshold', methods=['POST'])
def set_threshold():
    global control
    v = request.args.get('value', '4')
    try:
        control['threshold'] = int(v)
        save_control()
        return jsonify({"status": "ok", "threshold": control['threshold']})
    except:
        return jsonify({"status": "error"}), 400

def get_market():
    try:
        t = exchange.fetch_ticker('ETH/USDT:USDT')
        vol = t.get('quoteVolume', 0) or 0
        return {
            'price': f"${t['last']:,.2f}",
            'change': round(t.get('percentage',0) or 0,2),
            'volume': f"${vol/1e6:.1f}M",
            'regime': 'trend' if abs(t.get('percentage',0) or 0)>1 else 'range'
        }
    except:
        return {'price': 'N/A', 'change': 0, 'volume': 'N/A', 'regime': 'error'}

def load_stats():
    try:
        if V38_STATS.exists(): return json.load(open(V38_STATS))
    except: pass
    try:
        if V36_STATS.exists(): return json.load(open(V36_STATS))
    except: pass
    return {"total_trades":0,"wins":0,"losses":0,"total_pnl":0,"signals_checked":0,"signals_passed":0,"trades":[]}

def load_log():
    lines = []
    log_file = V38_LOG if V38_LOG.exists() else V36_LOG
    try:
        if log_file.exists():
            for line in open(log_file).readlines()[-20:]:
                line = line.strip()
                if not line: continue
                if '开仓' in line or '平仓' in line: lines.append({'t':line,'c':'trade'})
                elif 'total=4' in line or 'total=5' in line: lines.append({'t':line,'c':'success'})
                elif 'total=3' in line: lines.append({'t':line,'c':'warning'})
                else: lines.append({'t':line,'c':''})
    except: pass
    return lines

