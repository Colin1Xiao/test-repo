# frp 服务器端配置示例
# 将此文件复制到你的服务器上，重命名为 frps.ini

[common]
# 监听端口
bind_port = 7000

# 认证 token（客户端需要相同）
token = YOUR_SECURE_TOKEN

# 仪表盘（可选）
dashboard_port = 7500
dashboard_user = admin
dashboard_pwd = YOUR_DASHBOARD_PASSWORD

# 日志
log_file = ./frps.log
log_level = info
log_max_days = 30

# 心跳检测
heartbeat_timeout = 90

# 允许端口范围（可选）
# allow_ports = 8000-9000

# 最大连接数
max_pool_count = 50

# TCP 多路复用
tcp_mux = true
