# DDNS 配置文件
# 复制为 ddns.conf 并填入你的信息

# 选择提供商: duckdns 或 cloudflare
PROVIDER=duckdns

# ============================================
# DuckDNS 配置（推荐，免费简单）
# 注册: https://www.duckdns.org/
# ============================================
DUCKDNS_DOMAIN=your-domain
DUCKDNS_TOKEN=your-token

# 示例:
# DUCKDNS_DOMAIN=xiaolong-control
# 访问地址: http://xiaolong-control.duckdns.org:8767

# ============================================
# Cloudflare 配置（如果你有域名）
# ============================================
# PROVIDER=cloudflare
# CF_ZONE_ID=your-zone-id
# CF_RECORD_ID=your-record-id
# CF_NAME=control.your-domain.com
# CF_TOKEN=your-api-token
