import json
import logging
import time
from enum import Enum
from datetime import datetime
from typing import Optional, Dict, Any
import threading

class ExecutionState(Enum):
    """执行状态枚举"""
    IDLE = "IDLE"  # 空闲等待
    SIGNAL_DETECTED = "SIGNAL_DETECTED"  # 信号检测
    ENTRY_ORDER_PENDING = "ENTRY_ORDER_PENDING"  # 入场挂单中
    ENTRY_PARTIALLY_FILLED = "ENTRY_PARTIALLY_FILLED"  # 入场部分成交
    POSITION_OPEN = "POSITION_OPEN"  # 持仓中
    EXIT_ORDER_PENDING = "EXIT_ORDER_PENDING"  # 平仓挂单中
    EXIT_PARTIALLY_FILLED = "EXIT_PARTIALLY_FILLED"  # 平仓部分成交
    EMERGENCY_EXIT_TRIGGERED = "EMERGENCY_EXIT_TRIGGERED"  # 紧急平仓触发
    POSITION_CLOSED = "POSITION_CLOSED"  # 持仓已平
    ERROR_RECOVERY = "ERROR_RECOVERY"  # 错误恢复

class ExecutionStateMachine:
    """执行状态机类"""
    
    def __init__(self, adapter, config):
        """
        初始化执行状态机
        
        Args:
            adapter: 交易所适配器实例
            config: 动态配置对象
        """
        self.adapter = adapter
        self.config = config
        self.current_state = ExecutionState.IDLE
        self.logger = logging.getLogger(__name__)
        
        # 状态相关数据
        self.position_info = {}
        self.entry_orders = []
        self.exit_orders = []
        self.last_signal = None
        self.entry_start_time = None
        self.exit_start_time = None
        self.requote_count = 0
        
        # 状态持久化文件
        self.state_file = "execution_state.json"
        
        # 加载之前的状态
        self.load_state()
        
        # 日志配置
        self.setup_logging()
    
    def setup_logging(self):
        """设置日志记录"""
        handler = logging.FileHandler('execution_state_machine.log')
        formatter = logging.Formatter('%(asctime)s - %(levelname)s - %(message)s')
        handler.setFormatter(formatter)
        self.logger.addHandler(handler)
        self.logger.setLevel(logging.INFO)
    
    def transition_to(self, new_state: ExecutionState, reason: str = ""):
        """记录状态转换日志"""
        log_msg = f"STATE TRANSITION: {old_state.value} -> {new_state.value}"
        if reason:
            log_msg += f" (Reason: {reason})"
        
        self.logger.info(log_msg)
        print(log_msg)  # 同时打印到控制台
    
    def transition_to(self, new_state:         logger.info("调用 transition_to")
ExecutionState, reason: str = ""):
        """状态转换"""
        old_state = self.current_state
        if old_state != new_state:
            self.log_state_transition(old_state, new_state, reason)
            
            # 根据状态转换发送告警
            self.send_alert_on_state_change(old_state, new_state, reason)
            
            self.current_state = new_state
            self.save_state()
    
    def send_alert_on_state_change(self, old_state: ExecutionState, new_state: ExecutionState, reason: str = ""):
        """根据状态变化发送告警"""
        critical_states = [
            ExecutionState.EMERGENCY_EXIT_TRIGGERED,
            ExecutionState.ERROR_RECOVERY
        ]
        
        if new_state in critical_states:
            alert_msg = f"🚨 CRITICAL STATE CHANGE: {old_state.value} -> {new_state.value}"
            if reason:
                alert_msg += f" | Reason: {reason}"
            self.send_telegram_alert(alert_msg)
        elif new_state in [ExecutionState.SIGNAL_DETECTED, ExecutionState.POSITION_OPEN, ExecutionState.POSITION_CLOSED]:
            # 重要交易状态变化
            alert_msg = f"📊 TRADE STATE CHANGE: {new_state.value}"
            if reason:
                alert_msg += f" | Reason: {reason}"
            self.send_telegram_alert(alert_msg)
    
    def save_state(self):
        """保存当前状态到文件"""
        state_data = {
            'current_state': self.current_state.value,
            'timestamp': datetime.now().isoformat(),
            'position_info': self.position_info,
            'entry_orders': self.entry_orders,
            'exit_orders': self.exit_orders,
            'last_signal': self.last_signal,
            'entry_start_time': self.entry_start_time.isoformat() if self.entry_start_time else None,
            'exit_start_time': self.exit_start_time.isoformat() if self.exit_start_time else None,
            'requote_count': self.requote_count
        }
        
        try:
            with open(self.state_file, 'w') as f:
                json.dump(state_data, f, indent=2)
        except Exception as e:
            self.logger.error(f"Failed to save state: {e}")
    
    def load_state(self):
        """从文件加载状态"""
        try:
            with open(self.state_file, 'r') as f:
                state_data = json.load(f)
                
            self.current_state = ExecutionState(state_data.get('current_state', 'IDLE'))
            self.position_info = state_data.get('position_info', {})
            self.entry_orders = state_data.get('entry_orders', [])
            self.exit_orders = state_data.get('exit_orders', [])
            self.last_signal = state_data.get('last_signal', None)
            
            if state_data.get('entry_start_time'):
                self.entry_start_time = datetime.fromisoformat(state_data['entry_start_time'])
            if state_data.get('exit_start_time'):
                self.exit_start_time = datetime.fromisoformat(state_data['exit_start_time'])
                
            self.requote_count = state_data.get('requote_count', 0)
            
            self.logger.info(f"Loaded state: {self.current_state.value}")
        except FileNotFoundError:
            self.logger.info("No previous state file found, starting fresh")
        except Exception as e:
            self.logger.error(f"Failed to load state: {e}")
    
    def detect_signal(self, signal_data: Dict[str, Any]):
        """检测到交易信号"""
        if self.current_state == ExecutionState.IDLE:
            self.last_signal = signal_data
            self.transition_to(ExecutionState.SIGNAL_DETECTED, "New trading signal detected")
            return True
        else:
            self.logger.warning(f"Signal detected but current state is {self.current_state.value}, ignoring")
            return False
    
    def enter_position_limit_order(self, signal_params: Dict[str, Any]) -> bool:
        """
        挂单进场逻辑
        - 接收信号参数
        - 创建限价挂单
        - 支持分层挂单 (30%/40%/30%)
        - 设置超时机制 (30秒)
        - 支持重挂 (最多2次)
        - 支持post-only模式
        """
        if self.current_state not in [ExecutionState.SIGNAL_DETECTED, ExecutionState.ERROR_RECOVERY]:
            self.logger.warning(f"Cannot enter position from state {self.current_state.value}")
            return False
        
        try:
            self.logger.info("Starting limit order entry process")
            self.transition_to(ExecutionState.ENTRY_ORDER_PENDING, "Placing limit entry orders")
            
            # 获取信号参数
            symbol = signal_params.get('symbol')
            direction = signal_params.get('direction')  # 'long' or 'short'
            quantity = signal_params.get('quantity')
            entry_price = signal_params.get('entry_price')
            
            # 分层挂单 (30%/40%/30%)
            total_qty = float(quantity)
            levels = [
                {'ratio': 0.3, 'price_offset': -0.001 if direction == 'long' else 0.001},  # 30%
                {'ratio': 0.4, 'price_offset': -0.002 if direction == 'long' else 0.002},  # 40%
                {'ratio': 0.3, 'price_offset': -0.003 if direction == 'long' else 0.003}   # 30%
            ]
            
            placed_orders = []
            self.entry_start_time = datetime.now()
            
            for i, level in enumerate(levels):
                qty = total_qty * level['ratio']
                price = entry_price * (1 + level['price_offset'])
                
                # 根据配置决定是否使用post-only模式
                if self.config.get('enable_post_only', True):
                    order = self.adapter.place_post_only_order(
                        symbol=symbol,
                        side='buy' if direction == 'long' else 'sell',
                        quantity=qty,
                        price=price
                    )
                else:
                    order = self.adapter.place_limit_order(
                        symbol=symbol,
                        side='buy' if direction == 'long' else 'sell',
                        quantity=qty,
                        price=price
                    )
                
                if order:
                    placed_orders.append({
                        'order_id': order.get('order_id'),
                        'price': price,
                        'quantity': qty,
                        'level': i+1
                    })
                    self.logger.info(f"Placed entry order {i+1}: {qty}@{price}")
                else:
                    self.logger.error(f"Failed to place entry order {i+1}")
            
            self.entry_orders = placed_orders
            
            # 检查是否有订单完全成交
            fully_filled = self.check_order_fill_status(placed_orders, is_entry=True)
            
            if fully_filled:
                self.logger.info("Entry orders fully filled")
                self.transition_to(ExecutionState.POSITION_OPEN, "Position opened successfully")
                return True
            else:
                # 启动超时检查线程
                threading.Thread(target=self._check_entry_timeout, daemon=True).start()
                return True
                
        except Exception as e:
            self.logger.error(f"Error in enter_position_limit_order: {e}")
            self.transition_to(ExecutionState.ERROR_RECOVERY, f"Entry order error: {str(e)}")
            return False
    
    def _check_entry_timeout(self):
        """检查入场订单超时"""
        timeout_seconds = self.config.get('entry_timeout_seconds', 30)
        
        while self.current_state == ExecutionState.ENTRY_ORDER_PENDING:
            time.sleep(1)
            elapsed = (datetime.now() - self.entry_start_time).total_seconds()
            
            if elapsed >= timeout_seconds:
                self.logger.info(f"Entry order timeout after {elapsed}s")
                
                # 检查当前成交情况
                filled_qty = self.calculate_filled_quantity(self.entry_orders, is_entry=True)
                total_qty = sum(order['quantity'] for order in self.entry_orders)
                
                if filled_qty > 0:
                    # 部分成交
                    self.logger.info(f"Entry partially filled: {filled_qty}/{total_qty}")
                    self.transition_to(ExecutionState.ENTRY_PARTIALLY_FILLED, 
                                     f"Partially filled after timeout: {filled_qty}/{total_qty}")
                    
                    # 根据配置决定是否重挂
                    max_requotes = self.config.get('max_entry_requotes', 2)
                    if self.requote_count < max_requotes:
                        self.requote_count += 1
                        self.logger.info(f"Attempting requote #{self.requote_count}")
                        self.enter_position_limit_order(self.last_signal)
                    else:
                        self.logger.info("Max requotes reached, considering position open")
                        self.transition_to(ExecutionState.POSITION_OPEN, "Position opened with partial fill")
                else:
                    # 完全未成交，根据配置决定是否重挂
                    max_requotes = self.config.get('max_entry_requotes', 2)
                    if self.requote_count < max_requotes:
                        self.requote_count += 1
                        self.logger.info(f"Requoting entry order #{self.requote_count}")
                        self.enter_position_limit_order(self.last_signal)
                    else:
                        self.logger.error("Entry timeout with max requotes reached")
                        self.transition_to(ExecutionState.ERROR_RECOVERY, "Entry failed after max attempts")
                break
    
    def exit_position_limit_order(self) -> bool:
        """
        挂单平仓逻辑
        - 创建限价平仓单
        - 支持分批止盈 (30%/40%/30%)
        - 设置超时机制 (15秒)
        - 支持重挂 (最多2次)
        - 超时升级紧急平仓
        """
        if self.current_state != ExecutionState.POSITION_OPEN:
            self.logger.warning(f"Cannot exit position from state {self.current_state.value}")
            return False
        
        try:
            self.logger.info("Starting limit order exit process")
            self.transition_to(ExecutionState.EXIT_ORDER_PENDING, "Placing limit exit orders")
            
            # 获取持仓信息
            position = self.adapter.get_position(self.position_info.get('symbol', ''))
            if not position or float(position.get('size', 0)) == 0:
                self.logger.warning("No position to exit")
                self.transition_to(ExecutionState.POSITION_CLOSED, "Position already closed")
                return True
            
            symbol = position.get('symbol')
            position_size = abs(float(position.get('size', 0)))
            side = 'sell' if float(position.get('size', 0)) > 0 else 'buy'  # 正数为多头，负数为空头
            mark_price = float(position.get('mark_price', 0))
            
            # 分批止盈 (30%/40%/30%)
            total_qty = position_size
            levels = [
                {'ratio': 0.3, 'price_offset': 0.001 if side == 'sell' else -0.001},  # 30%
                {'ratio': 0.4, 'price_offset': 0.002 if side == 'sell' else -0.002},  # 40%
                {'ratio': 0.3, 'price_offset': 0.003 if side == 'sell' else -0.003}   # 30%
            ]
            
            placed_orders = []
            self.exit_start_time = datetime.now()
            
            for i, level in enumerate(levels):
                qty = total_qty * level['ratio']
                price = mark_price * (1 + level['price_offset'])
                
                order = self.adapter.place_limit_order(
                    symbol=symbol,
                    side=side,
                    quantity=qty,
                    price=price
                )
                
                if order:
                    placed_orders.append({
                        'order_id': order.get('order_id'),
                        'price': price,
                        'quantity': qty,
                        'level': i+1
                    })
                    self.logger.info(f"Placed exit order {i+1}: {qty}@{price}")
                else:
                    self.logger.error(f"Failed to place exit order {i+1}")
            
            self.exit_orders = placed_orders
            
            # 检查是否有订单完全成交
            fully_filled = self.check_order_fill_status(placed_orders, is_entry=False)
            
            if fully_filled:
                self.logger.info("Exit orders fully filled")
                self.transition_to(ExecutionState.POSITION_CLOSED, "Position closed successfully")
                return True
            else:
                # 启动超时检查线程
                threading.Thread(target=self._check_exit_timeout, daemon=True).start()
                return True
                
        except Exception as e:
            self.logger.error(f"Error in exit_position_limit_order: {e}")
            self.transition_to(ExecutionState.ERROR_RECOVERY, f"Exit order error: {str(e)}")
            return False
    
    def _check_exit_timeout(self):
        """检查平仓订单超时"""
        timeout_seconds = self.config.get('exit_timeout_seconds', 15)
        
        while self.current_state == ExecutionState.EXIT_ORDER_PENDING:
            time.sleep(1)
            elapsed = (datetime.now() - self.exit_start_time).total_seconds()
            
            if elapsed >= timeout_seconds:
                self.logger.info(f"Exit order timeout after {elapsed}s")
                
                # 检查当前成交情况
                filled_qty = self.calculate_filled_quantity(self.exit_orders, is_entry=False)
                total_qty = sum(order['quantity'] for order in self.exit_orders)
                
                if filled_qty > 0:
                    # 部分成交
                    self.logger.info(f"Exit partially filled: {filled_qty}/{total_qty}")
                    self.transition_to(ExecutionState.EXIT_PARTIALLY_FILLED, 
                                     f"Partially filled after timeout: {filled_qty}/{total_qty}")
                    
                    # 根据配置决定是否重挂
                    max_requotes = self.config.get('max_exit_requotes', 2)
                    if self.requote_count < max_requotes:
                        self.requote_count += 1
                        self.logger.info(f"Attempting exit requote #{self.requote_count}")
                        self.exit_position_limit_order()
                    else:
                        self.logger.info("Max exit requotes reached, triggering emergency exit")
                        self.emergency_exit_market()
                else:
                    # 完全未成交，触发紧急平仓
                    self.logger.info("Exit timeout with no fills, triggering emergency exit")
                    self.emergency_exit_market()
                break
    
    def emergency_exit_market(self):
        """
        紧急平仓例外
        - 取消所有挂单
        - 获取最新持仓
        - 市价强平
        - 验证仓位归零
        - 发送关键告警
        - 进入冷静期 (30分钟)
        """
        self.logger.warning("Triggering emergency exit")
        self.transition_to(ExecutionState.EMERGENCY_EXIT_TRIGGERED, "Emergency market exit initiated")
        
        try:
            # 1. 取消所有挂单
            self.logger.info("Cancelling all pending orders...")
            self.adapter.cancel_all_orders()
            
            # 2. 获取最新持仓
            position = self.adapter.get_position()
            if not position or float(position.get('size', 0)) == 0:
                self.logger.info("No position to emergency exit")
                self.transition_to(ExecutionState.POSITION_CLOSED, "No position to close")
                return
            
            symbol = position.get('symbol')
            position_size = abs(float(position.get('size', 0)))
            side = 'sell' if float(position.get('size', 0)) > 0 else 'buy'
            
            self.logger.info(f"Current position: {position_size} {symbol}, side: {side}")
            
            # 3. 市价强平
            order_result = self.adapter.close_position_emergency(symbol, position_size, side)
            
            if order_result:
                self.logger.info("Emergency market order placed successfully")
                
                # 4. 验证仓位归零
                time.sleep(2)  # 等待订单执行
                verification_position = self.adapter.get_position(symbol)
                remaining_size = float(verification_position.get('size', 0)) if verification_position else 0
                
                if abs(remaining_size) < 0.001:  # 基本归零
                    self.logger.info("Position successfully closed via emergency exit")
                    self.transition_to(ExecutionState.POSITION_CLOSED, "Position closed via emergency exit")
                    
                    # 5. 发送关键告警
                    alert_msg = f"🚨 EMERGENCY EXIT EXECUTED 🚨\n"
                    alert_msg += f"Symbol: {symbol}\n"
                    alert_msg += f"Size: {position_size}\n"
                    alert_msg += f"Side: {side}\n"
                    alert_msg += f"Status: SUCCESSFULLY CLOSED"
                    self.send_telegram_alert(alert_msg)
                    
                    # 6. 进入冷静期 (30分钟)
                    self.start_cooldown_period()
                else:
                    self.logger.error(f"Emergency exit failed, remaining position: {remaining_size}")
                    self.transition_to(ExecutionState.ERROR_RECOVERY, 
                                     f"Emergency exit failed, remaining: {remaining_size}")
            else:
                self.logger.error("Failed to place emergency market order")
                self.transition_to(ExecutionState.ERROR_RECOVERY, "Emergency exit order failed")
                
        except Exception as e:
            self.logger.error(f"Error in emergency_exit_market: {e}")
            self.transition_to(ExecutionState.ERROR_RECOVERY, f"Emergency exit error: {str(e)}")
    
    def start_cooldown_period(self):
        """开始冷静期"""
        cooldown_seconds = self.config.get('cooldown_after_emergency_exit_seconds', 1800)  # 30分钟
        self.logger.info(f"Starting cooldown period: {cooldown_seconds}s")
        
        # 发送冷静期开始通知
        alert_msg = f"⏳ COOLDOWN PERIOD STARTED ⏳\nDuration: {cooldown_seconds}s ({cooldown_seconds/60:.1f}min)"
        self.send_telegram_alert(alert_msg)
        
        time.sleep(cooldown_seconds)
        
        self.logger.info("Cooldown period ended")
        alert_msg = "✅ COOLDOWN PERIOD ENDED ✅\nSystem ready for new trades"
        self.send_telegram_alert(alert_msg)
        
        # 回到空闲状态
        self.transition_to(ExecutionState.IDLE, "Cooldown period ended, ready for new signals")
    
    def check_order_fill_status(self, orders, is_entry: bool) -> bool:
        """检查订单成交状态，返回是否全部成交"""
        try:
            total_quantity = sum(order['quantity'] for order in orders)
            filled_quantity = 0
            
            for order in orders:
                order_status = self.adapter.get_order_status(order['order_id'])
                if order_status and order_status.get('status') == 'filled':
                    filled_quantity += order['quantity']
                elif order_status and order_status.get('status') == 'partially_filled':
                    filled_quantity += float(order_status.get('filled_quantity', 0))
            
            if filled_quantity >= total_quantity * 0.99:  # 容忍1%的舍入误差
                return True
            else:
                return False
        except Exception as e:
            self.logger.error(f"Error checking order fill status: {e}")
            return False
    
    def calculate_filled_quantity(self, orders, is_entry: bool) -> float:
        """计算已成交数量"""
        try:
            filled_quantity = 0
            
            for order in orders:
                order_status = self.adapter.get_order_status(order['order_id'])
                if order_status:
                    status = order_status.get('status', '')
                    if status == 'filled':
                        filled_quantity += order['quantity']
                    elif status == 'partially_filled':
                        filled_quantity += float(order_status.get('filled_quantity', 0))
            
            return filled_quantity
        except Exception as e:
            self.logger.error(f"Error calculating filled quantity: {e}")
            return 0
    
