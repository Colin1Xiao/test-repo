#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
启动完整交易系统
使用 requests 版本的 OKX API 客户端
"""

import subprocess
import os
import time
from datetime import datetime

print("="*70)
print("🚀 启动小龙智能交易系统 v2.0")
print("="*70)
print()

# 系统配置
config = {
    'symbols': ['BTC/USDT:USDT', 'ETH/USDT:USDT', 'SOL/USDT:USDT'],
    'leverage': {
        'BTC/USDT:USDT': 100,
        'ETH/USDT:USDT': 100,
        'SOL/USDT:USDT': 50
    },
    'check_interval': 60,  # 60 秒
    'order_type': 'limit',  # 限价单
    'emergency_order_type': 'market',  # 紧急市价单
}

print("📋 系统配置:")
print(f"   监控标的：{len(config['symbols'])} 个")
for symbol in config['symbols']:
    lev = config['leverage'].get(symbol, 50)
    print(f"   - {symbol}: {lev}x 杠杆")
print(f"   检查间隔：{config['check_interval']}秒")
print(f"   默认订单：{config['order_type']} (限价单)")
print(f"   紧急订单：{config['emergency_order_type']} (市价单)")
print()

print("⚠️  风险提示:")
print(f"   🔴 BTC/ETH: 100x 杠杆 (1% 爆仓)")
print(f"   🔴 SOL: 50x 杠杆 (2% 爆仓)")
print(f"   🔴 当前资金：$14.44")
print(f"   🔴 建议追加资金到$100+")
print()

print("="*70)
print("🔧 启动步骤")
print("="*70)
print()

# 步骤 1: 设置代理
print("1️⃣  设置代理环境变量...")
os.environ['https_proxy'] = 'http://127.0.0.1:7890'
os.environ['http_proxy'] = 'http://127.0.0.1:7890'
print(f"   ✅ https_proxy={os.environ['https_proxy']}")
print()

# 步骤 2: 测试 API 连接
print("2️⃣  测试 OKX API 连接...")
try:
    from okx_api_client import OKXClient
    client = OKXClient()
    
    # 测试获取 BTC 价格
    result = client.fetch_ticker('BTC/USDT:USDT')
    if result['success']:
        btc_price = float(result['data'][0]['last'])
        print(f"   ✅ API 连接成功")
        print(f"   ✅ BTC 价格：${btc_price:,.2f}")
    else:
        print(f"   ⚠️  API 连接警告：{result['error']}")
except Exception as e:
    print(f"   ❌ API 测试失败：{e}")
print()

# 步骤 3: 启动监控系统
print("3️⃣  启动监控系统...")
print("   命令：python3 okx_api_client.py")
print("   模式：后台运行")
print()

# 步骤 4: 后台运行
print("4️⃣  设置后台运行...")
print("   日志文件：monitor_live.log")
print("   告警文件：monitor_alerts.log")
print()

print("="*70)
print("✅ 系统启动命令")
print("="*70)
print()
print("# 前台运行（查看实时日志）")
print("cd /Users/colin/.openclaw/workspace")
print("python3 okx_api_client.py")
print()
print("# 后台运行（推荐）")
print("cd /Users/colin/.openclaw/workspace")
print("nohup python3 okx_api_client.py > monitor_live.log 2>&1 &")
print()
print("# 查看进程")
print("ps aux | grep okx_api")
print()
print("# 查看日志")
print("tail -f monitor_live.log")
print()
print("# 停止系统")
print("pkill -f okx_api")
print()

print("="*70)
print("📊 实时监控")
print("="*70)
print()
print("Notion 仪表盘:")
print("   https://www.notion.so/32071d2818c48035919ffbdd05eea938")
print()
print("Telegram 告警:")
print("   已配置，重要信号自动推送")
print()

print("="*70)
print("🎯 交易策略")
print("="*70)
print()
print("   限价单挂单:")
print("      - 分批挂单 (3 批)")
print("      - 价格偏移：±0.1%")
print("      - 资金分配：50%/30%/20%")
print()
print("   智能撤单:")
print("      - 超时撤单 (3 分钟)")
print("      - 信号失效撤单")
print("      - 市场变化撤单 (>1%)")
print()
print("   止损止盈:")
print("      - 止损：0.5% (市价单)")
print("      - 止盈：1.5% (限价单)")
print()

print("="*70)
print("⏱️  系统将在 5 秒后自动启动...")
print("="*70)
print()

time.sleep(5)

# 启动监控系统
print("🚀 启动监控系统...")
try:
    # 停止旧进程
    subprocess.run(['pkill', '-f', 'okx_api_client'], capture_output=True)
    time.sleep(2)
    
    # 启动新进程
    log_file = open('/Users/colin/.openclaw/workspace/monitor_live.log', 'a')
    subprocess.Popen(
        ['python3', '/Users/colin/.openclaw/workspace/okx_api_client.py'],
        cwd='/Users/colin/.openclaw/workspace',
        stdout=log_file,
        stderr=subprocess.STDOUT
    )
    
    print("✅ 监控系统已启动！")
    print()
    print("📊 查看实时日志:")
    print("   tail -f /Users/colin/.openclaw/workspace/monitor_live.log")
    print()
    print("📱 Telegram 告警已启用")
    print("📊 Notion 仪表盘已连接")
    print()
    print("="*70)
    print("🎉 小龙智能交易系统运行中！")
    print("="*70)
    
except Exception as e:
    print(f"❌ 启动失败：{e}")
    print()
    print("请手动运行:")
    print("   cd /Users/colin/.openclaw/workspace")
    print("   python3 okx_api_client.py")